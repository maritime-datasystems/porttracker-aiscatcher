<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- Remote Access -->
    <PreferenceCategory
        android:title="Remote Access"
        app:iconSpaceReserved="false">

        <EditTextPreference
            android:key="pref_porttracker_username"
            android:title="Porttracker Username"
            android:summary="Enter your Porttracker username"
            android:defaultValue=""
            app:iconSpaceReserved="false" />

        <EditTextPreference
            android:key="pref_station_name"
            android:title="Porttracker AIS Station Name"
            android:summary="Enter a name for your station"
            android:defaultValue=""
            app:iconSpaceReserved="false" />

        <SwitchPreferenceCompat
            android:key="pref_enable_remote"
            android:title="Enable Remote Access"
            android:summary="Create a tunnel for remote access to web interface"
            android:defaultValue="false"
            app:iconSpaceReserved="false" />

        <Preference
            android:key="pref_remote_status"
            android:title="Remote Access URL"
            android:summary="Not launched"
            android:selectable="true"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <!-- Local Web Server -->
    <PreferenceCategory
        android:title="Local Web Server"
        app:iconSpaceReserved="false">

        <SwitchPreferenceCompat
            android:key="webviewer_enabled"
            android:title="Enable Web Viewer"
            android:summary="Web-based map and status"
            android:defaultValue="true"
            app:iconSpaceReserved="false" />

        <EditTextPreference
            android:key="pref_local_web_port"
            android:title="Local Web Port"
            android:summary="8080"
            android:defaultValue="8080"
            android:inputType="number"
            android:dependency="webviewer_enabled"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <!-- DNS Settings -->
    <PreferenceCategory
        android:title="DNS Configuration"
        app:iconSpaceReserved="false">

        <SwitchPreferenceCompat
            android:key="dns_manual"
            android:title="Manual DNS Settings"
            android:summary="Override system DNS"
            android:defaultValue="false"
            app:iconSpaceReserved="false" />

        <EditTextPreference
            android:key="dns_primary"
            android:title="Primary DNS"
            android:summary="8.8.8.8"
            android:defaultValue="8.8.8.8"
            android:dependency="dns_manual"
            app:iconSpaceReserved="false" />

        <EditTextPreference
            android:key="dns_secondary"
            android:title="Secondary DNS"
            android:summary="8.8.4.4"
            android:defaultValue="8.8.4.4"
            android:dependency="dns_manual"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <!-- Network Routing & Diagnostics -->
    <PreferenceCategory
        android:title="Networking Tools"
        app:iconSpaceReserved="false">

        <Preference
            android:key="net_diagnostics"
            android:title="Network Diagnostics"
            android:summary="Tap to run network tests"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

</PreferenceScreen>
