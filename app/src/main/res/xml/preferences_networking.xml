<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- Community Hub (aiscatcher.org) -->
    <PreferenceCategory
        android:title="Community Hub"
        app:iconSpaceReserved="false">

        <SwitchPreferenceCompat
            android:key="hub_sharing"
            android:title="Feed Community Hub"
            android:summary="Share your AIS data with aiscatcher.org"
            android:defaultValue="false"
            app:iconSpaceReserved="false" />

        <EditTextPreference
            android:key="hub_key"
            android:title="Sharing Key"
            android:summary="Enter your UUID from aiscatcher.org"
            android:dependency="hub_sharing"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <!-- External Web Portal / Remote Access -->
    <PreferenceCategory
        android:title="External Web Portal"
        app:iconSpaceReserved="false">

        <EditTextPreference
            android:key="pref_porttracker_username"
            android:title="Porttracker Username"
            android:summary="Enter your Porttracker username"
            android:defaultValue=""
            app:iconSpaceReserved="false" />

        <EditTextPreference
            android:key="pref_station_name"
            android:title="Porttracker AIS Station Name"
            android:summary="Enter a name for your station"
            android:defaultValue=""
            app:iconSpaceReserved="false" />

        <SwitchPreferenceCompat
            android:key="pref_enable_remote"
            android:title="Enable External Web Portal / Access"
            android:summary="Create a tunnel for remote access to web interface"
            android:defaultValue="false"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <!-- DNS Settings -->
    <PreferenceCategory
        android:title="DNS Configuration"
        app:iconSpaceReserved="false">

        <SwitchPreferenceCompat
            android:key="dns_manual"
            android:title="Manual DNS Settings"
            android:summary="Override system DNS"
            android:defaultValue="false"
            app:iconSpaceReserved="false" />

        <EditTextPreference
            android:key="dns_primary"
            android:title="Primary DNS"
            android:summary="8.8.8.8"
            android:defaultValue="8.8.8.8"
            android:dependency="dns_manual"
            app:iconSpaceReserved="false" />

        <EditTextPreference
            android:key="dns_secondary"
            android:title="Secondary DNS"
            android:summary="8.8.4.4"
            android:defaultValue="8.8.4.4"
            android:dependency="dns_manual"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <!-- Network Routing & Diagnostics -->
    <PreferenceCategory
        android:title="Networking Tools"
        app:iconSpaceReserved="false">

        <Preference
            android:key="net_diagnostics"
            android:title="Network Diagnostics"
            android:summary="Tap to run network tests"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

</PreferenceScreen>
